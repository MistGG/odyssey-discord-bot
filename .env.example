DISCORD_BOT_TOKEN=
DISCORD_CLIENT_ID=
# Optional: guild ID for dev testing (slash commands register faster)
DISCORD_DEV_GUILD_ID=

# Default alert channel if no DB config (v1 single-server)
DISCORD_ALERT_CHANNEL_ID=
DISCORD_PING_ROLE_ID=
DISCORD_PATCH_NOTES_CHANNEL_ID=

# Comma-separated lead times in minutes before spawn
ALERT_LEAD_MINUTES=5,2

# Poll interval ms (default 60000)
RAID_POLL_MS=60000

# Raid poll interval while a train is active (default 10000)
ACTIVE_TRAIN_POLL_MS=10000

# Patch notes poll interval ms (default 300000 = 5 min)
PATCH_NOTES_POLL_MS=300000
